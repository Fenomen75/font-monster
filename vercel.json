{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!sitemap.xml|robots.txt|.*\\..*).*)", "destination": "/index.html" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
